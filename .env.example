# =============================================================================
# .env.example — Copy to .env and fill in your credentials
# NEVER commit .env to version control
# =============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/grand_olive

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key-here
EMAIL_FROM_ADDRESS=reservations@thegrandolive.com
EMAIL_FROM_NAME=The Grand Olive

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+447911000000

# ── CORS / Security ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://www.thegrandolive.com","http://localhost:3000"]
ALLOWED_HOSTS=["api.thegrandolive.com","localhost"]
